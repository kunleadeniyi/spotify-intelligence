{
  "title": "Platform Overview",
  "uid": "platform-overview",
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total{job=\"fastapi\"}[1m])",
          "legendFormat": "{{method}} {{handler}} {{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "API p95 Latency (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"fastapi\"}[5m]))",
          "legendFormat": "p95 {{handler}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Recommendations Served",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(recommendations_served_total[5m])",
          "legendFormat": "{{source}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "API Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total{job=\"fastapi\", status_code=~\"5..\"}[1m])",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "kafka_consumer_group_lag{job=\"kafka\"}",
          "legendFormat": "{{topic}} / {{consumergroup}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Kafka Messages In/s",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(kafka_topic_partition_current_offset{job=\"kafka\"}[1m])",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Postgres Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "pg_stat_database_numbackends{job=\"postgres\", datname=\"spotify\"}",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "id": 8,
      "title": "Redis Memory Used (MB)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "redis_memory_used_bytes{job=\"redis\"} / 1024 / 1024",
          "legendFormat": "used MB"
        }
      ]
    },
    {
      "id": 9,
      "title": "Redis Hit Rate",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(redis_keyspace_hits_total{job=\"redis\"}[1m]) / (rate(redis_keyspace_hits_total{job=\"redis\"}[1m]) + rate(redis_keyspace_misses_total{job=\"redis\"}[1m]))",
          "legendFormat": "hit rate"
        }
      ]
    }
  ]
}
