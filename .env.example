# Spotify API
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_TOKEN_CACHE=./cache/.cache

# Postgres
POSTGRES_HOST=localhost
POSTGRES_HOST_INTERNAL=postgres
POSTGRES_PORT=5432
POSTGRES_DB=spotify

POSTGRES_ADMIN_USER=admin-sa
POSTGRES_ADMIN_PASSWORD=admin-sa

PG_SPOTIFY_DB_USER=spotify-sa
PG_SPOTIFY_DB_USER_PASSWORD=spotify-sa
PG_SPOTIFY_DB=spotify

PG_PREFECT_USER=prefect-sa
PG_PREFECT_USER_PASSWORD=prefect-sa
PG_PREFECT_DB=prefect

# Connection URL (assembled from above — used by SQLAlchemy / dbt / Feast)
DATABASE_URL=postgresql://${PG_SPOTIFY_DB_USER}:${PG_SPOTIFY_DB_USER_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${PG_SPOTIFY_DB}

# Kafka
KAFKA_BOOTSTRAP_SERVERS_INTERNAL=broker:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PLAY_EVENTS=spotify.play.events
KAFKA_TOPIC_AUDIO_FEATURES=spotify.audio.features
KAFKA_TOPIC_ARTIST_GENRES=spotify.artist.genres
KAFKA_CONSUMER_GROUP_ID=spotify-consumer-group

# Redis (Feast online store)
REDIS_HOST=localhost
REDIS_HOST_INTERNAL=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5555
MLFLOW_EXPERIMENT_NAME=spotify-recommendations

# Prefect
PREFECT_API_URL=http://localhost:4200/api


# FastAPI
API_HOST=0.0.0.0
API_PORT=8000


# Streamlit
STREAMLIT_API_BASE_URL=http://localhost:8000
